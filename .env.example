# Copie este arquivo para .env.local e preencha com suas credenciais reais

# Firebase (obrigatório)
VITE_FIREBASE_API_KEY=sua_api_key
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_APP_ID=seu-projeto

# Notificações por e-mail via Resend (opcional)
# Crie conta em resend.com e obtenha a chave
RESEND_API_KEY=re_xxxxxxxxxxxx

# E-mail remetente (deve ser um domínio verificado no Resend)
EMAIL_FROM=Fotus Agro <notificacoes@seudominio.com.br>
